{
  "name": "libscope",
  "version": "1.8.0",
  "description": "AI-powered knowledge base with MCP integration — query library docs, internal wikis, and topics with semantic search",
  "homepage": "https://libscope.com",
  "type": "module",
  "bin": {
    "libscope": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp": "./dist/mcp/server.js",
    "./lite": {
      "import": "./dist/lite/index.js",
      "require": "./dist/lite/index.js",
      "types": "./dist/lite/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/parsers && tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ tests/ packages/",
    "lint:fix": "eslint src/ tests/ packages/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'packages/parsers/src/**/*.ts' 'packages/parsers/tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'packages/parsers/src/**/*.ts' 'packages/parsers/tests/**/*.ts'",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "npm run test --workspace=packages/parsers && vitest run",
    "test:watch": "vitest",
    "test:coverage": "npm run test --workspace=packages/parsers && vitest run --coverage",
    "prepare": "husky",
    "serve": "node dist/mcp/server.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "mcp",
    "documentation",
    "ai",
    "llm",
    "knowledge-base",
    "semantic-search",
    "model-context-protocol",
    "embeddings"
  ],
  "author": "RobertLD",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/RobertLD/libscope.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@libscope/parsers": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "sqlite-vec": "^0.1.0",
    "undici": "^7.24.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0",
    "tree-sitter-c": "^0.21.0",
    "tree-sitter-c-sharp": "^0.21.0",
    "tree-sitter-cpp": "^0.22.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    },
    "tree-sitter-javascript": {
      "optional": true
    },
    "tree-sitter-typescript": {
      "optional": true
    },
    "tree-sitter-python": {
      "optional": true
    },
    "tree-sitter-c-sharp": {
      "optional": true
    },
    "tree-sitter-cpp": {
      "optional": true
    },
    "tree-sitter-c": {
      "optional": true
    },
    "tree-sitter-go": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "flatted": ">=3.4.2"
  }
}
