# LibScope Environment Variables
# Copy this file to .env and fill in your values.

# Embedding provider: "local" | "ollama" | "openai" (default: "local")
LIBSCOPE_EMBEDDING_PROVIDER=local

# Ollama settings (required when provider is "ollama")
LIBSCOPE_OLLAMA_URL=http://localhost:11434
LIBSCOPE_OLLAMA_MODEL=nomic-embed-text

# OpenAI settings (required when provider is "openai")
LIBSCOPE_OPENAI_API_KEY=
