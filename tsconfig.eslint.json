{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-test",
    "declaration": false,
    "declarationMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "packages/parsers/src/**/*.ts", "packages/parsers/tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
